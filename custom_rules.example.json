{
  "inspection_commands": {
    "cisco": {
      "ios": [
        "show inventory"
      ]
    },
    "user-custom": {
      "custom-os": [
        "show version",
        "show system"
      ]
    }
  },
  "backup_commands": {
    "user-custom": {
      "custom-os": "show running-config"
    }
  },
  "parsing_rules": {
    "cisco": {
      "ios": {
        "show inventory": {
          "pattern": "NAME:\\s+\\\"(.*?)\\\"",
          "output_column": "Inventory Name",
          "first_match_only": true
        }
      }
    },
    "user-custom": {
      "custom-os": {
        "show version": {
          "pattern": "Version\\s*[:=]\\s*(\\S+)",
          "output_column": "Version",
          "first_match_only": true
        },
        "show system": {
          "patterns": [
            {
              "pattern": "Hostname\\s*[:=]\\s*(\\S+)",
              "output_column": "Hostname",
              "first_match_only": true
            },
            {
              "pattern": "Uptime\\s*[:=]\\s*(.*)",
              "output_column": "Uptime",
              "first_match_only": true
            }
          ]
        }
      }
    }
  },
  "connection_overrides": {
    "user-custom": {
      "custom-os": {
        "default": "cisco_ios",
        "telnet": "cisco_ios_telnet"
      }
    }
  }
}
